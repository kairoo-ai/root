# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Neon Database (Postgres)
# Get from https://neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/kairoo?sslmode=require

# Razorpay
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Google AI (Gemini) - already in use
GOOGLE_GENERATIVE_AI_API_KEY=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Non-LLM compute service (HuggingFace Space) ---
COMPUTE_SERVICE_URL=
COMPUTE_SHARED_SECRET=
# --- Durable rate limiting (optional overrides; defaults 300000ms / 20 req) ---
AI_RATE_WINDOW_MS=
AI_RATE_MAX_REQ=
